<Window x:Class="QuanLyPhongKham_Final.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:QuanLyPhongKham_Final.Views"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="Quản Lý Phòng Khám - Danh Sách Khám Bệnh" Height="650" Width="1000" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Dòng 0: Tiêu đề BM1 -->
            <RowDefinition Height="Auto"/>
            <!-- Dòng 1: Ngày khám & Loại phòng khám -->
            <RowDefinition Height="Auto"/>
            <!-- Dòng 1.5: Chọn bệnh nhân và thêm vào danh sách -->
            <RowDefinition Height="*"/>
            <!-- Dòng 2: Bảng DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Dòng 3: Nút Lưu -->
        </Grid.RowDefinitions>

        <!-- Dòng 0: Tiêu đề BM1 (Nền vàng) -->
        <materialDesign:Card Grid.Row="0" Background="LightGoldenrodYellow" Padding="12" Margin="0,0,0,20" UniformCornerRadius="4">
            <TextBlock Text="BM1: Danh Sách Khám Bệnh" FontSize="22" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="Black"/>
        </materialDesign:Card>

        <!-- Dòng 1: Ngày khám & Loại phòng khám -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Chọn Ngày Khám -->
            <DatePicker x:Name="dpNgayKham" 
                        materialDesign:HintAssist.Hint="Ngày khám" 
                        Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                        VerticalAlignment="Center"
                        FontSize="15"
                        SelectedDate="{Binding NgayKham, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Chọn Loại Phòng Khám -->
            <ComboBox x:Name="cbLoaiPhongKham" Grid.Column="2" 
                      materialDesign:HintAssist.Hint="Loại phòng khám"
                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                      ItemsSource="{Binding DanhSachLoaiPhong}" 
                      SelectedItem="{Binding LoaiPhongDuocChon}"
                      DisplayMemberPath="TenLoaiPhongKham"
                      SelectedValuePath="MaLoaiPhongKham"
                      VerticalAlignment="Center"
                      FontSize="15"/>
        </Grid>

        <!-- Dòng 1.5: Chọn bệnh nhân và nút thêm -->
        <Grid Grid.Row="2" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ComboBox chọn bệnh nhân -->
            <ComboBox x:Name="cbBenhNhanDuocChon"
                      materialDesign:HintAssist.Hint="Chọn bệnh nhân"
                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                      ItemsSource="{Binding DanhSachAllBenhNhan}"
                      SelectedItem="{Binding BenhNhanDuocChon, UpdateSourceTrigger=PropertyChanged}"
                      VerticalAlignment="Center"
                      FontSize="15">
                
                <!-- Template cho dropdown list items -->
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Tên bệnh nhân (rõ ràng) -->
                            <TextBlock Grid.Row="0" 
                                       Text="{Binding HoTen}" 
                                       FontSize="15" 
                                       FontWeight="Bold"
                                       Foreground="Black"/>
                            
                            <!-- Thông tin khác (mờ và chữ nhỏ) -->
                            <TextBlock Grid.Row="1" 
                                       Margin="0,2,0,0"
                                       FontSize="12" 
                                       Opacity="0.6"
                                       Foreground="Gray">
                                <Run Text="Mã: "/>
                                <Run Text="{Binding MaBenhNhan, Mode=OneWay}"/>
                                <Run Text=" | Năm sinh: "/>
                                <Run Text="{Binding NamSinh, Mode=OneWay}"/>
                                <Run Text=" | "/>
                                <Run Text="{Binding GioiTinh, Mode=OneWay}"/>
                                <Run Text=" | "/>
                                <Run Text="{Binding DiaChi, Mode=OneWay}"/>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Nút Thêm Bệnh Nhân -->
            <Button Grid.Column="2" x:Name="btnThemBenhNhan" 
                    Content="➕ Thêm BN"
                    Style="{StaticResource MaterialDesignRaisedDarkButton}"
                    Width="120" Height="40"
                    VerticalAlignment="Center"
                    Command="{Binding ThemBenhNhanCommand}"/>
        </Grid>

        <!-- Dòng 2: DataGrid Danh sách Bệnh Nhân -->
        <DataGrid Grid.Row="3" x:Name="dgDanhSachBenhNhan"
                  ItemsSource="{Binding DanhSachBenhNhan}"
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  CanUserDeleteRows="True"
                  HeadersVisibility="Column"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="10"
                  Background="{DynamicResource MaterialDesignPaper}"
                  RowHeight="40">

            <DataGrid.Columns>
                <!-- STT -->
                <DataGridTextColumn Header="STT" Binding="{Binding STT}" IsReadOnly="True" Width="50"/>
                
                <!-- Họ Tên (Read-only) -->
                <DataGridTextColumn Header="Họ Tên" Binding="{Binding HoTen}" 
                                    Width="300" IsReadOnly="True"/>
                
                <!-- Giới Tính (Read-only) -->
                <DataGridTextColumn Header="Giới Tính" Binding="{Binding GioiTinh}" 
                                    Width="1*" IsReadOnly="True"/>
                
                <!-- Năm Sinh (Read-only) -->
                <DataGridTextColumn Header="Năm Sinh" Binding="{Binding NamSinh}" 
                                    Width="1*" IsReadOnly="True"/>
                
                <!-- Địa Chỉ (Read-only) -->
                <DataGridTextColumn Header="Địa Chỉ" Binding="{Binding DiaChi}" 
                                    Width="2*" IsReadOnly="True"/>
                
                <!-- Mã BN (Read-only) -->
                <!--<DataGridTextColumn Header="Mã BN" Binding="{Binding MaBenhNhan}" 
                                    Width="100" IsReadOnly="True"/>-->
            </DataGrid.Columns>
        </DataGrid>

        <!-- Dòng 3: Nút Lưu -->
        <Button Grid.Row="4" x:Name="btnSave" Content="💾 LƯU PHIẾU KHÁM" 
                Margin="0,20,0,0" HorizontalAlignment="Right" Width="180" Height="40"
                Style="{StaticResource MaterialDesignRaisedDarkButton}"
                Command="{Binding LuuPhieuKhamCommand}"/>
    </Grid>
</Window>