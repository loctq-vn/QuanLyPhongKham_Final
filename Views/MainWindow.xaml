<Window x:Class="QuanLyPhongKham_Final.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:QuanLyPhongKham_Final.Views"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="Quản Lý Phòng Khám - Danh Sách Khám Bệnh" Height="600" Width="900" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Ngày khám & Loại phòng khám -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Button -->
        </Grid.RowDefinitions>

        <!-- Tiêu đề BM1 (Nền vàng) -->
        <materialDesign:Card Grid.Row="0" Background="LightGoldenrodYellow" Padding="12" Margin="0,0,0,20" UniformCornerRadius="4">
            <TextBlock Text="BM1: Danh Sách Khám Bệnh" FontSize="22" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="Black"/>
        </materialDesign:Card>

        <!-- Ngày khám & Loại phòng khám -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- DatePicker Ngày Khám -->
            <DatePicker x:Name="dpNgayKham" 
                        materialDesign:HintAssist.Hint="Ngày khám"
                        Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                        VerticalAlignment="Center"
                        FontSize="15"/>

            <!-- ComboBox Loại Phòng Khám -->
            <ComboBox x:Name="cbLoaiPhongKham" Grid.Column="2" 
                      materialDesign:HintAssist.Hint="Loại phòng khám"
                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                      ItemsSource="{Binding DanhSachLoaiPhong}" 
                      SelectedItem="{Binding LoaiPhongDuocChon}"
                      DisplayMemberPath="TenLoaiPhongKham"
                      SelectedValuePath="MaLoaiPhongKham"
                      VerticalAlignment="Center"
                      FontSize="15"/>
        </Grid>

        <!-- ScrollViewer cho DataGrid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Visible">
            <!-- DataGrid Danh sách Bệnh Nhân -->
            <DataGrid x:Name="dgDanhSachBenhNhan"
                      ItemsSource="{Binding DanhSachBenhNhan}"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="True"
                      CanUserDeleteRows="True"
                      CanUserResizeColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#CCCCCC"
                      VerticalGridLinesBrush="#CCCCCC"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="10"
                      Background="White"
                      RowHeight="40">

                <DataGrid.Columns>
                    <!-- STT -->
                    <DataGridTextColumn Header="STT" Binding="{Binding STT}" IsReadOnly="True" Width="60"/>
                    
                    <!-- Họ Tên -->
                    <DataGridTextColumn Header="Họ Tên" Binding="{Binding HoTen}" 
                                        Width="200"/>
                    
                    <!-- Giới Tính -->
                    <DataGridTextColumn Header="Giới Tính" Binding="{Binding GioiTinh}" 
                                        Width="100"/>
                    
                    <!-- Năm Sinh -->
                    <DataGridTextColumn Header="Năm Sinh" Binding="{Binding NamSinh}" 
                                        Width="100"/>
                    
                    <!-- Địa Chỉ -->
                    <DataGridTextColumn Header="Địa Chỉ" Binding="{Binding DiaChi}" 
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>

        <!-- Nút Tiếp Nhận Danh Sách -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,20,0,0">
            <!-- Nút Tiếp Nhận Danh Sách -->
            <Button x:Name="btnTiepNhanDanhSach"
            Content="Tiếp Nhận Danh Sách"
            Padding="16,8"
            Margin="0,0,10,0"
            Style="{StaticResource MaterialDesignRaisedButton}"
            Background="#1976D2"
            Foreground="White"
            FontSize="14"
            FontWeight="Medium"/>

            <!-- Nút Cập Nhật -->
            <Button x:Name="btnCapNhat"
            Content="Cập Nhật"
            Padding="16,8"
            Margin="150,0,150,0"
            Style="{StaticResource MaterialDesignRaisedButton}"
            Background="#1976D2"
            Foreground="White"
            FontSize="14"
            FontWeight="Medium"/>

            <!-- Nút Xóa -->
            <Button x:Name="btnXoa"
            Content="Xóa"
            Padding="16,8"
            Style="{StaticResource MaterialDesignRaisedButton}"
            Background="#1976D2"
            Foreground="White"
            FontSize="14"
            FontWeight="Medium"/>
        </StackPanel>
        <Button Grid.Row="3" 
                x:Name="btnThoat"
                Content="Thoát"
                HorizontalAlignment="Right"
                Padding="16,8"
                Style="{StaticResource MaterialDesignRaisedButton}"
                Margin="0,10,0,0"
                Background="#1976D2"
                Foreground="White"
                FontSize="14"
                FontWeight="Medium"/>
    </Grid>
</Window>