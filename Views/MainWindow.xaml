<Window x:Class="QuanLyPhongKham_Final.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="Quản Lý Phòng Khám - Danh Sách Khám Bệnh" Height="650" Width="900" WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Dòng 0: Tiêu đề BM1 -->
            <RowDefinition Height="Auto"/> <!-- Dòng 1: Ngày khám & Loại phòng khám -->
            <RowDefinition Height="*"/>    <!-- Dòng 2: Bảng DataGrid -->
            <RowDefinition Height="Auto"/> <!-- Dòng 3: Nút Lưu -->
        </Grid.RowDefinitions>

        <!-- Dòng 0: Tiêu đề BM1 (Nền vàng) -->
        <materialDesign:Card Grid.Row="0" Background="LightGoldenrodYellow" Padding="12" Margin="0,0,0,20" UniformCornerRadius="4">
            <TextBlock Text="BM1: Danh Sách Khám Bệnh" FontSize="22" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="Black"/>
        </materialDesign:Card>

        <!-- Dòng 1: Ngày khám & Loại phòng khám -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Chọn Ngày Khám -->
            <DatePicker x:Name="dpNgayKham" 
                        materialDesign:HintAssist.Hint="Ngày khám" 
                        Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                        VerticalAlignment="Center"
                        FontSize="15"
                        SelectedDate="{Binding NgayKham, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Chọn Loại Phòng Khám -->
            <ComboBox x:Name="cbLoaiPhongKham" Grid.Column="2" 
                      materialDesign:HintAssist.Hint="Loại phòng khám"
                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                      ItemsSource="{Binding DanhSachLoaiPhong}" 
                      SelectedItem="{Binding LoaiPhongDuocChon}"
                      DisplayMemberPath="TenLoaiPhongKham"
                      SelectedValuePath="MaLoaiPhongKham"
                      VerticalAlignment="Center"
                      FontSize="15"/>
        </Grid>

        <!-- Dòng 2: DataGrid Danh sách Bệnh Nhân -->
        <DataGrid Grid.Row="2" x:Name="dgDanhSachBenhNhan"
                  ItemsSource="{Binding DanhSachBenhNhan}"
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  CanUserDeleteRows="True"
                  HeadersVisibility="Column"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="10"
                  Background="{DynamicResource MaterialDesignPaper}"
                  RowHeight="40">

            <DataGrid.Columns>
                <!-- STT -->
                <DataGridTextColumn Header="STT" Binding="{Binding STT}" IsReadOnly="True"/>
                
                <!-- Bệnh Nhân (ComboBox với autocomplete) -->
                <DataGridTemplateColumn Header="Họ Tên" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding HoTen}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox x:Name="cbBenhNhanCell"
                                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.DanhSachBenhNhan}"
                                      SelectedValuePath="MaBenhNhan"
                                      DisplayMemberPath="HoTen"
                                      Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                
                <!-- Giới Tính -->
                <DataGridTextColumn Header="Giới Tính" Binding="{Binding GioiTinh}" IsReadOnly="False" Width="1*"/>
                
                <!-- Năm Sinh -->
                <DataGridTextColumn Header="Năm Sinh" Binding="{Binding NamSinh}" IsReadOnly="False" Width="1*"/>
                
                <!-- Địa Chỉ -->
                <DataGridTextColumn Header="Địa Chỉ" Binding="{Binding DiaChi}" IsReadOnly="False" Width="3*"/>
                
                <!-- Thao tác -->
                <DataGridTemplateColumn Header="Thao tác" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                    Foreground="#D32F2F" Content="Xóa" Padding="4" Height="25"
                                    ToolTip="Xóa bệnh nhân khỏi danh sách"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Dòng 4: Nút Lưu -->
        <Button Grid.Row="4" x:Name="btnSave" Content="LƯU PHIẾU KHÁM" 
                Margin="0,20,0,0" HorizontalAlignment="Right" Width="180" Height="40"
                Style="{StaticResource MaterialDesignRaisedDarkButton}"/>
    </Grid>
</Window>
